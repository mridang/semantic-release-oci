{
  "name": "@mridang/semantic-release-oci",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "prepack": "tsc",
    "build": "tsc",
    "test": "jest --verbose --config=jest.config.mjs --runInBand",
    "test:watch": "npm run test -- --watch",
    "test:debug": "jest --verbose --config=jest.config.mjs --runInBand --detectOpenHandles",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "npx eslint .",
    "lint:fix": "npx eslint . --fix"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "keywords": [
    "semver",
    "nodejs",
    "semantic-release",
    "docker",
    "oci"
  ],
  "author": {
    "name": "Mridang Agarwalla",
    "email": "mridang.agarwalla@gmail.com",
    "url": "https://github.com/mridang"
  },
  "files": [
    "dist"
  ],
  "license": "Apache-2.0",
  "description": "Semantic Release plugin that builds, tags, and pushes Docker/OCI images to a container registry",
  "private": false,
  "engines": {
    "node": ">=22.0.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mridang/semantic-release-oci.git"
  },
  "homepage": "https://github.com/mridang/semantic-release-oci",
  "bugs": "https://github.com/mridang/semantic-release-oci/issues",
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@semantic-release/error": "^4.0.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.0.3",
    "@mridang/eslint-defaults": "^1.4.0",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.0",
    "@semantic-release/npm": "^13.1.1",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.0",
    "eslint": "^10.1.0",
    "jest": "^30.0.3",
    "jest-junit": "^16.0.0",
    "knip": "^6.1.1",
    "prettier": "^3.1.1",
    "semantic-release": "^25.0.1",
    "ts-jest": "^29.4.0",
    "typescript": "^6.0.2"
  },
  "publishConfig": {
    "access": "public"
  }
}
